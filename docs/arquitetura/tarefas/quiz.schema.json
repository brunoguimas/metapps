{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "QuizTask",
    "type": "object",
    "required": [
        "title",
        "type",
        "description",
        "expectation",
        "questions"
    ],
    "properties": {
        "title": {
            "type": "string",
            "minLength": 3
        },
        "type": {
            "type": "string",
            "const": "quiz"
        },
        "description": {
            "type": "string"
        },
        "expectation": {
            "type": "string"
        },
        "questions": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "required": [
                    "question",
                    "type",
                    "answer"
                ],
                "properties": {
                    "material": {
                        "type": "string"
                    },
                    "question": {
                        "type": "string",
                        "minLength": 3
                    },
                    "type": {
                        "type": "string",
                        "enum": [
                            "options",
                            "text"
                        ]
                    },
                    "options": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "minItems": 2
                    },
                    "explanation": {
                        "type": "string"
                    },
                    "answer": {
                        "oneOf": [
                            {
                                "type": "integer",
                                "minimum": 0
                            },
                            {
                                "type": "string"
                            }
                        ]
                    }
                },
                "allOf": [
                    {
                        "if": {
                            "properties": {
                                "type": {
                                    "const": "options"
                                }
                            }
                        },
                        "then": {
                            "required": [
                                "options"
                            ],
                            "properties": {
                                "answer": {
                                    "type": "integer"
                                }
                            }
                        }
                    },
                    {
                        "if": {
                            "properties": {
                                "type": {
                                    "const": "text"
                                }
                            }
                        },
                        "then": {
                            "properties": {
                                "answer": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                ]
            }
        }
    },
    "additionalProperties": false
}
